{
  "name": "meta-doc",
  "version": "0.17.8",
  "description": "基于LLM Agent的智能文字处理软件",
  "main": "./out/main/index.js",
  "author": "ByteLight",
  "homepage": "https://electron-vite.org",
  "repository": {
    "type": "git",
    "url": "https://github.com/JaredYe04/MetaDoc.git"
  },
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint . --ext .js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix",
    "start": "electron-vite preview",
    "dev": "concurrently \"electron-vite dev\" \"vite\"",
    "open-test": "concurrently \"electron-vite dev -- c:\\Users\\tange\\Documents\\软件工程概述和流程.md\" \"vite\"",
    "prebuild": "node scripts/copy-env.js",
    "build": "npm run prebuild && electron-vite build",
    "temp-build": "electron-vite build",
    "build:sequential": "npm run prebuild && node scripts/build-sequential.js",
    "postinstall": "node scripts/postinstall-electron.js && (electron-builder install-app-deps || echo \"Warning: Some native dependencies (e.g. canvas) may need manual setup\") && npm run rebuild-native",
    "rebuild-native": "electron-rebuild -f -w better-sqlite3 --only better-sqlite3",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "temp-build:win": "npm run temp-build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux",
    "build:android": "npm run build && npx cap copy && npx cap sync android && npx cap open android",
    "android": "npx cap open android",
    "kill": "taskkill /IM electron.exe /F",
    "i18n": "python .\\src\\renderer\\src\\locales\\i18n_check.py",
    "clean:vite": "rimraf node_modules/.vite || rm -rf node_modules/.vite",
    "audit": "node scripts/code-audit.js",
    "compose-doc-icons": "node scripts/compose-doc-icons.js",
    "generate-icons": "node scripts/generate-icons.js",
    "release:dev": "node scripts/release-dev.js",
    "release:prod": "node scripts/release-prod.js",
    "release:rollback": "node scripts/release-rollback.js",
    "changelog": "node scripts/generate-changelog.js",
    "update:licenses": "node scripts/update-open-source-licenses.js"
  },
  "fileAssociations": [
    {
      "ext": "md",
      "name": "Markdown Document",
      "description": "Markdown 文件",
      "role": "Editor",
      "mimeType": "text/markdown",
      "icon": "build/md-icon.ico"
    },
    {
      "ext": "tex",
      "name": "LaTeX Document",
      "description": "LaTeX 文件",
      "role": "Editor",
      "mimeType": "text/latex",
      "icon": "build/tex-icon.ico"
    }
  ],
