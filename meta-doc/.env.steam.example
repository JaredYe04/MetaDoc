# Steam 渠道 / 本地联调 Cloud Worker：将下列变量写入 meta-doc/.env（pnpm dev / electron-vite 会加载），
# 或复制本文件为 .env.steam 并在对应 mode 的构建中使用，或由 CI 注入。
# VITE_STEAM_DISTRIBUTION=true
# VITE_METADOC_CLOUD_API_URL=https://your-worker.workers.dev

# 仅 pnpm dev：在 Debug 页选择「官方云」时，与 Worker 的 ALLOW_DEV_AUTH / DEV_AUTH_SECRET 配对
# VITE_METADOC_CLOUD_DEV_AUTH_SECRET=your-dev-secret
# VITE_METADOC_CLOUD_DEV_STEAM_ID=76561197960265728
